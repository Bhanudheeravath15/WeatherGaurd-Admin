# Database Connection
MONGODB_URI=mongodb://localhost:27017/weatherguard

# JWT Secret
JWT_SECRET=super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Telegram Bot Token (Get from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_USERNAME=WeatherGuardBot

# Social Logins
# For GitHub Login
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET
GITHUB_REDIRECT_URI=http://localhost:5173/login

# Weather API (OpenWeatherMap - Optional, mock will be used if empty)
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY
# Default city if user doesn't configure one
DEFAULT_LAT=40.7128
DEFAULT_LON=-74.0060
